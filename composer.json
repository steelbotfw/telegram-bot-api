{
    "name": "steelbotfw/telegram-bot-api",
    "description": "Telegram bot API implementation using Amphp",
    "keywords": ["bot", "telegram", "asynchronous", "api"],
    "license": "BSD-3-Clause",
    "authors": [
        {
            "name": "Pavel Chebotarev",
            "email": "chebotarevp@gmail.com"
        }
    ],
    "support": {
        "issues": "https://github.com/steelbotfw/telegram-bot-api/issues",
        "source": "https://github.com/steelbotfw/telegram-bot-api"
    },
    "type": "library",
    "minimum-stability": "dev",
    "require": {
        "php": ">=7.4",
        "ext-json": "*",
        "ext-mbstring": "*",

        "amphp/amp": "^2.6.0",
        "amphp/http-client": "^4.6.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.6",
        "vimeo/psalm": "^5.26"
    },
    "scripts": {
        "test": "./vendor/bin/phpunit"
    },
    "autoload": {
        "psr-4": {
            "Steelbot\\TelegramBotApi\\": "src"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Steelbot\\Tests\\TelegramBotApi\\": "tests"
        }
    },
    "config": {
        "audit": {
            "block-insecure": false
        },
        "platform": {
            "php": "7.4.0"
        }
    }
}
